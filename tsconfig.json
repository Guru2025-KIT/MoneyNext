{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@moneynext/shared": ["./packages/shared/src"],
      "@moneynext/config": ["./packages/config/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
